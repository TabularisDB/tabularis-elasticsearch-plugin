{
  "name": "tabularis-elasticsearch-plugin",
  "version": "0.1.1",
  "description": "Browse Elasticsearch indices, inspect mappings, and run queries directly from Tabularis.",
  "category": "search",
  "kind": "driver",
  "tags": ["elasticsearch", "search", "observability", "logs", "nosql"],
  "license": "Apache-2.0",
  "icon": "https://raw.githubusercontent.com/TabularisDB/tabularis-elasticsearch-plugin/main/elasticsearch-logo.svg",
  "homepage": "https://github.com/TabularisDB/tabularis-elasticsearch-plugin",
  "documentation_url": "https://github.com/TabularisDB/tabularis-elasticsearch-plugin#readme",
  "support": {
    "issues_url": "https://github.com/TabularisDB/tabularis-elasticsearch-plugin/issues"
  },
  "readme": "README.md",
  "engine": "elasticsearch",
  "paradigms": ["search", "document"],
  "color": "#FEC514",
  "default_port": 9200,
  "default_username": "elastic",
  "executable": "elasticsearch-plugin",
  "capabilities": {
    "schemas": false,
    "views": false,
    "routines": false,
    "file_based": false,
    "folder_based": false,
    "no_connection_required": true,
    "identifier_quote": "\"",
    "alter_primary_key": false,
    "alter_column": false,
    "create_foreign_keys": false,
    "manage_tables": false,
    "readonly": true,
    "connection_string_example": "http://elastic:elastic@localhost:9200"
  },
  "data_types": [
    {
      "name": "BOOLEAN",
      "category": "boolean",
      "requires_length": false,
      "requires_precision": false
    },
    {
      "name": "INTEGER",
      "category": "numeric",
      "requires_length": false,
      "requires_precision": false
    },
    {
      "name": "BIGINT",
      "category": "numeric",
      "requires_length": false,
      "requires_precision": false
    },
    {
      "name": "FLOAT",
      "category": "numeric",
      "requires_length": false,
      "requires_precision": false
    },
    {
      "name": "DOUBLE",
      "category": "numeric",
      "requires_length": false,
      "requires_precision": false
    },
    {
      "name": "TEXT",
      "category": "string",
      "requires_length": false,
      "requires_precision": false
    },
    {
      "name": "VARCHAR",
      "category": "string",
      "requires_length": true,
      "requires_precision": false
    },
    {
      "name": "TIMESTAMP",
      "category": "datetime",
      "requires_length": false,
      "requires_precision": false
    },
    {
      "name": "DATE",
      "category": "datetime",
      "requires_length": false,
      "requires_precision": false
    },
    {
      "name": "JSON",
      "category": "json",
      "requires_length": false,
      "requires_precision": false
    }
  ]
}
