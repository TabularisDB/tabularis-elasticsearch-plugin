{
  "$schema": "https://tabularis.dev/schemas/plugin-manifest.json",
  "id": "elasticsearch",
  "name": "Elasticsearch",
  "version": "0.1.0",
  "description": "Tabularis driver plugin for Elasticsearch",
  "default_port": 5432,
  "default_username": "",
  "executable": "elasticsearch-plugin",
  "capabilities": {
    "schemas": false,
    "views": false,
    "routines": false,
    "file_based": false,
    "folder_based": false,
    "no_connection_required": false,
    "identifier_quote": "\"",
    "alter_primary_key": false,
    "alter_column": false,
    "create_foreign_keys": false,
    "manage_tables": false,
    "readonly": true
  },
  "data_types": [
    {
      "name": "INTEGER",
      "category": "numeric",
      "requires_length": false,
      "requires_precision": false
    },
    {
      "name": "TEXT",
      "category": "string",
      "requires_length": false,
      "requires_precision": false
    }
  ]
}
